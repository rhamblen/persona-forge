{
  "id": "base-character",
  "name": "Base character (single image)",
  "description": "Phase A / Prompt Studio: generate one image from the character, style and negative prompts. Used to refine a prompt before signing it off.",
  "file": "base-character.json",
  "output_node": "12",
  "params": {
    "character":   { "node": "2",  "input": "value",           "type": "text",  "label": "Character",  "multiline": true },
    "style":       { "node": "3",  "input": "value",           "type": "text",  "label": "Style + framing", "multiline": true },
    "negative":    { "node": "4",  "input": "value",           "type": "text",  "label": "Negative",   "multiline": true },
    "expression":  { "node": "5",  "input": "value",           "type": "text",  "label": "Expression suffix" },
    "checkpoint":  { "node": "1",  "input": "ckpt_name",       "type": "model", "label": "Checkpoint", "model_type": "checkpoints" },
    "width":       { "node": "9",  "input": "width",           "type": "int",   "label": "Width",  "min": 512, "max": 2048, "step": 64 },
    "height":      { "node": "9",  "input": "height",          "type": "int",   "label": "Height", "min": 512, "max": 2048, "step": 64 },
    "seed":        { "node": "10", "input": "seed",            "type": "int",   "label": "Seed" },
    "steps":       { "node": "10", "input": "steps",           "type": "int",   "label": "Steps",  "min": 1,  "max": 80 },
    "cfg":         { "node": "10", "input": "cfg",             "type": "float", "label": "CFG",    "min": 1.0, "max": 12.0, "step": 0.1 },
    "sampler":     { "node": "10", "input": "sampler_name",    "type": "enum",  "label": "Sampler" },
    "scheduler":   { "node": "10", "input": "scheduler",       "type": "enum",  "label": "Scheduler" },
    "output_prefix": { "node": "12", "input": "filename_prefix", "type": "path", "label": "Output prefix" }
  }
}
