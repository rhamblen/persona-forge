# Persona Forge — live config for this stack.
# Shipped ready to use: copy docker/ to the server and adjust the paths below.
# Holds no secrets. If you ever add a credential, move it out of version control.
# ---------------------------------------------------------------------------

# ComfyUI (external, already running on UR1)
COMFYUI_URL=http://192.168.1.33:9000

# Host path of the SHARED builds folder.
# This MUST be the same host share that is mapped into the ComfyUI container
# (Unraid: container edit -> Add another Path -> /builds), so both ComfyUI and
# Persona Forge can read/write LoRAs and finished images.
#
# Keep this path free of spaces. Do NOT wrap it in quotes — docker compose would
# treat the quotes as part of the value.
BUILDS_HOST_PATH=/mnt/user/data-and-backups/blender-and-comfyui-output/comfyui-builds

# Persistent state. These sit as PEERS of the docker/ folder:
#   /mnt/user/appdata/persona-forge/{docker,db,logs}
#
# USE ABSOLUTE PATHS. A relative path is resolved against docker compose's
# *project directory*, which Unraid's Compose Manager does not always set to this
# file's folder — that is what nested them inside docker/ before 0.2.6.
DB_HOST_PATH=/mnt/user/appdata/persona-forge/db
LOGS_HOST_PATH=/mnt/user/appdata/persona-forge/logs

# Port Persona Forge is published on
PF_PORT=8890

# Ownership for build folders Persona Forge creates in the shared builds tree.
# Must be a user the ComfyUI container can write as (Unraid: nobody:users).
PUID=99
PGID=100

TZ=Europe/London
