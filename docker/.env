# Persona Forge — live config for this stack.
# Shipped ready to use: copy docker/ to the server and adjust the paths below.
# Holds no secrets. If you ever add a credential, move it out of version control.
# ---------------------------------------------------------------------------

# ComfyUI (external, already running on UR1)
COMFYUI_URL=http://192.168.1.33:9000

# Default checkpoint for a NEW persona. ComfyUI lists checkpoints in folder order,
# so without this the first entry wins ("!first/...", photoreal) and the first
# generate looks wrong. DEFAULT_CHECKPOINT must match a name exactly; if it is
# missing from the server, the first model matching PREFERRED_CHECKPOINTS
# (comma-separated, case-insensitive substrings, in order) is used instead.
DEFAULT_CHECKPOINT=animi/NoobAI-XL-v1.1.safetensors
PREFERRED_CHECKPOINTS=NoobAI-XL,animi/,AnythingXL

# Ollama (external, on the LAN) — powers the AI prompt assistant. A small instruct
# model is enough; OLLAMA_MODEL must be one the box has pulled (see `ollama list`).
OLLAMA_URL=http://192.168.1.32:11434
OLLAMA_MODEL=llama3.1:latest

# Container control — lets the app restart ComfyUI/Ollama when they're down. PF talks
# ONLY to the scoped docker-socket-proxy service (see docker-compose.yml), never the
# raw socket. To DISABLE the whole feature, comment out DOCKER_PROXY_URL.
DOCKER_PROXY_URL=http://docker-socket-proxy:2375
# The real UR1 container names PF is allowed to start/restart.
COMFYUI_CONTAINER=stable-diffusion-ComfyUI
OLLAMA_CONTAINER=ollama
# Host path to the Docker socket (Unraid default shown). Mounted READ-ONLY into the
# proxy only. Pin DOCKER_PROXY_IMAGE to a release tag if you prefer over :latest.
DOCKER_SOCK_PATH=/var/run/docker.sock
#DOCKER_PROXY_IMAGE=tecnativa/docker-socket-proxy:latest

# Host path of the SHARED builds folder.
# This MUST be the same host share that is mapped into the ComfyUI container
# (Unraid: container edit -> Add another Path -> /builds), so both ComfyUI and
# Persona Forge can read/write LoRAs and finished images.
#
# Keep this path free of spaces. Do NOT wrap it in quotes — docker compose would
# treat the quotes as part of the value.
BUILDS_HOST_PATH=/mnt/user/data-and-backups/blender-and-comfyui-output/comfyui-builds

# Persistent state. These sit as PEERS of the docker/ folder:
#   /mnt/user/appdata/persona-forge/{docker,db,logs}
#
# USE ABSOLUTE PATHS. A relative path is resolved against docker compose's
# *project directory*, which Unraid's Compose Manager does not always set to this
# file's folder — that is what nested them inside docker/ before 0.2.6.
DB_HOST_PATH=/mnt/user/appdata/persona-forge/db
LOGS_HOST_PATH=/mnt/user/appdata/persona-forge/logs

# Port Persona Forge is published on
PF_PORT=8890

# Ownership for build folders Persona Forge creates in the shared builds tree.
# Must be a user the ComfyUI container can write as (Unraid: nobody:users).
PUID=99
PGID=100

TZ=Europe/London
